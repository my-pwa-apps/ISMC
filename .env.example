# ============================================================
# ISMC — Intune Settings Management Console
# Environment Configuration
# ============================================================
# Copy this file to .env.local and populate all required values.
# Never commit .env.local or any file containing real secrets.

# ============================================================
# Application
# ============================================================
NEXT_PUBLIC_APP_NAME="ISMC"
NEXT_PUBLIC_APP_VERSION="0.1.0"

# Environment: development | staging | production
NEXT_PUBLIC_ENVIRONMENT="development"

# Set to "true" to use mock data instead of real Graph API calls.
# Useful for local development without a real Entra tenant.
NEXT_PUBLIC_ENABLE_MOCK="true"

# ============================================================
# Authentication — Microsoft Entra ID (Azure AD)
# ============================================================
# Register an app in Entra ID (Azure Portal > App Registrations).
# See docs/deployment.md for step-by-step guidance.

# Your Entra tenant ID (Directory ID)
AUTH_ENTRA_TENANT_ID="YOUR_TENANT_ID"

# App registration client ID
AUTH_ENTRA_CLIENT_ID="YOUR_CLIENT_ID"

# App registration client secret (use Federated Credentials in prod)
AUTH_ENTRA_CLIENT_SECRET="YOUR_CLIENT_SECRET"

# Required Microsoft Graph delegated permissions (add these to your app registration):
#   DeviceManagementConfiguration.Read.All
#   DeviceManagementConfiguration.ReadWrite.All  (for write operations)
#   DeviceManagementManagedDevices.Read.All
#   DeviceManagementApps.Read.All
#   Group.Read.All
#   Policy.Read.All
#   RoleManagement.Read.Directory

# NextAuth secret — generate with: openssl rand -base64 32
AUTH_SECRET="GENERATE_A_STRONG_RANDOM_SECRET"

# Base URL of the application
NEXTAUTH_URL="http://localhost:3000"

# ============================================================
# Database
# ============================================================
# SQLite (development default — no server needed):
DATABASE_URL="file:./dev.db"

# Production uses Cloudflare D1 (bound as `DB` in wrangler.toml).
# No DATABASE_URL needed in production — the D1 binding is injected automatically.

# ============================================================
# Microsoft Graph
# ============================================================
# Override Graph base URLs if needed (e.g., for GCC or sovereign clouds)
GRAPH_STABLE_BASE_URL="https://graph.microsoft.com/v1.0"
GRAPH_BETA_BASE_URL="https://graph.microsoft.com/beta"

# Maximum retries for throttled Graph requests (429 responses)
GRAPH_MAX_RETRIES="3"

# Request timeout in milliseconds
GRAPH_TIMEOUT_MS="30000"

# ============================================================
# Feature Flags
# ============================================================
# Allow write operations (clone, create, update policies)
ENABLE_WRITE_OPERATIONS="false"

# Enable snapshot/versioning features
ENABLE_SNAPSHOTS="true"

# Enable GPO migration workspace
ENABLE_MIGRATION="true"

# ============================================================
# Logging
# ============================================================
# Log level: trace | debug | info | warn | error | fatal
LOG_LEVEL="info"

# Pretty-print logs in development (disable in production for JSON output)
LOG_PRETTY="true"
